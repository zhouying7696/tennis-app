{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS.Builder.Node"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "buildCommand": "cd backend && npm install",
    "startCommand": "cd backend && npm start"
  }
}
