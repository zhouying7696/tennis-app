{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS.Builder.Node",
    "install": {
      "command": "cd backend && npm install"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "command": "cd backend && npm start"
  }
}
