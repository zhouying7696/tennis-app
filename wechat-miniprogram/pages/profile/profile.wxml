<!-- profile.wxml -->
<view class="container">
  <!-- 状态栏 -->
  <view class="status-bar">
    <text class="status-time">{{ currentTime }}</text>
    <view class="status-icons">
      <text>📶</text>
      <text>🔋</text>
    </view>
  </view>

  <!-- 头部英雄区 -->
  <view class="profile-hero">
    <view class="profile-top">
      <view class="profile-avatar-wrap">
        <view class="profile-avatar">{{ user.name.charAt(0) }}</view>
        <view class="edit-avatar">✏️</view>
      </view>
      <view class="profile-info">
        <text class="profile-name">{{ user.name }}</text>
        <text class="profile-id">ID: {{ user.id }}</text>
      </view>
      <view class="profile-level-badge">{{ user.level }}</view>
    </view>
    <view class="profile-rating">
      <text class="stars">⭐⭐⭐⭐☆</text>
      <text class="rating-num">4.2</text>
      <text class="rating-count">(24)</text>
    </view>
  </view>

  <!-- 统计数据卡片 -->
  <view class="profile-stats">
    <view class="pstat">
      <text class="pstat-num">{{ user.stats.activities }}</text>
      <text class="pstat-label">参与活动</text>
    </view>
    <view class="pstat">
      <text class="pstat-num">{{ user.stats.wins }}</text>
      <text class="pstat-label">获胜场次</text>
    </view>
    <view class="pstat">
      <text class="pstat-num">{{ user.stats.ranking }}</text>
      <text class="pstat-label">排名</text>
    </view>
  </view>

  <!-- XP进度条 -->
  <view class="xp-card">
    <view class="xp-header">
      <text class="xp-title">经验值</text>
      <text class="xp-level">等级 {{ user.levelNum }}</text>
    </view>
    <view class="xp-bar-bg">
      <view class="xp-bar-fill" style="width: {{ user.xpPercentage }}%"></view>
    </view>
    <view class="xp-sub">
      <text>{{ user.currentXp }} / {{ user.nextLevelXp }} XP</text>
      <text>升级还需 {{ user.nextLevelXp - user.currentXp }} XP</text>
    </view>
  </view>

  <!-- 滚动内容区域 -->
  <scroll-view class="profile-scroll" scroll-y>
    <!-- 菜单区域 -->
    <view class="menu-section">
      <view class="menu-item" bindtap="navigateToMyActivities">
        <view class="menu-item-icon" style="background: #e8f7ef; color: #1a6b3c;">🏸</view>
        <view class="menu-item-text">
          <text class="menu-item-label">我的活动</text>
          <text class="menu-item-sub">查看我参与的活动</text>
        </view>
        <text class="menu-item-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="navigateToMyTournaments">
        <view class="menu-item-icon" style="background: #fff3e8; color: #e8621a;">🏆</view>
        <view class="menu-item-text">
          <text class="menu-item-label">我的比赛</text>
          <text class="menu-item-sub">查看我参与的比赛</text>
        </view>
        <text class="menu-item-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="navigateToMyVenues">
        <view class="menu-item-icon" style="background: #e8f0ff; color: #1a4eb8;">📍</view>
        <view class="menu-item-text">
          <text class="menu-item-label">常用场地</text>
          <text class="menu-item-sub">管理我的常用场地</text>
        </view>
        <text class="menu-item-arrow">›</text>
      </view>
    </view>

    <view class="menu-section">
      <view class="menu-item" bindtap="navigateToSettings">
        <view class="menu-item-icon" style="background: #f3e8ff; color: #6b1a8b;">⚙️</view>
        <view class="menu-item-text">
          <text class="menu-item-label">设置</text>
          <text class="menu-item-sub">账号与隐私设置</text>
        </view>
        <text class="menu-item-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="navigateToHelp">
        <view class="menu-item-icon" style="background: #ffe8e8; color: #c0392b;">❓</view>
        <view class="menu-item-text">
          <text class="menu-item-label">帮助与反馈</text>
          <text class="menu-item-sub">常见问题与意见反馈</text>
        </view>
        <text class="menu-item-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="navigateToAbout">
        <view class="menu-item-icon" style="background: #e8f7ef; color: #1a6b3c;">ℹ️</view>
        <view class="menu-item-text">
          <text class="menu-item-label">关于我们</text>
          <text class="menu-item-sub">版本信息与服务条款</text>
        </view>
        <text class="menu-item-arrow">›</text>
      </view>
    </view>

    <!-- 最近活动 -->
    <view class="recent-activities">
      <text class="ra-title">最近活动</text>
      <view class="ra-item">
        <view class="ra-dot" style="background: #1a6b3c;"></view>
        <text class="ra-text">参加了活动 "周末网球友谊赛"</text>
        <text class="ra-time">昨天</text>
      </view>
      <view class="ra-item">
        <view class="ra-dot" style="background: #e8621a;"></view>
        <text class="ra-text">创建了活动 "周三训练赛"</text>
        <text class="ra-time">3天前</text>
      </view>
      <view class="ra-item">
        <view class="ra-dot" style="background: #1a4eb8;"></view>
        <text class="ra-text">参加了活动 "初学者训练"</text>
        <text class="ra-time">1周前</text>
      </view>
    </view>

    <!-- 底部空间 -->
    <view style="height: 80px;"></view>
  </scroll-view>
</view>
