/* index.wxss */
.container {
  min-height: 100vh;
  background-color: #f4f6f8;
}

/* 状态栏 */
.status-bar {
  height: 44px;
  background: #1a6b3c;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  color: white;
  position: relative;
  z-index: 10;
}

.status-time {
  font-size: 15px;
  font-weight: 600;
}

.status-icons {
  display: flex;
  gap: 6px;
  align-items: center;
}

.status-icons text {
  font-size: 12px;
}

/* 头部区域 */
.home-header {
  background: linear-gradient(160deg, #1a6b3c 0%, #2d9e5f 100%);
  padding: 16px 20px 28px;
  position: relative;
  overflow: hidden;
}

.home-header::before {
  content: '';
  position: absolute;
  right: -30px;
  top: -30px;
  width: 160px;
  height: 160px;
  border: 2px solid rgba(255,255,255,0.08);
  border-radius: 50%;
}

.home-header::after {
  content: '';
  position: absolute;
  right: 10px;
  top: 10px;
  width: 100px;
  height: 100px;
  border: 2px solid rgba(255,255,255,0.06);
  border-radius: 50%;
}

.home-greeting {
  color: rgba(255,255,255,0.8);
  font-size: 13px;
  margin-bottom: 4px;
  display: block;
}

.home-name {
  color: white;
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 16px;
  display: block;
}

.home-stats {
  display: flex;
  gap: 12px;
}

.stat-pill {
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  border-radius: 20px;
  padding: 6px 14px;
  display: flex;
  align-items: center;
  gap: 6px;
  color: white;
  font-size: 12px;
  font-weight: 500;
}

.stat-pill .dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #7fff9f;
}

/* 搜索栏 */
.search-bar {
  margin: 16px;
  background: white;
  border-radius: 14px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}

.search-bar .icon {
  font-size: 16px;
}

.search-input {
  flex: 1;
  border: none;
  outline: none;
  font-size: 14px;
  color: #333;
  background: transparent;
}

.search-input::placeholder {
  color: #bbb;
}

.filter-btn {
  background: #1a6b3c;
  color: white;
  border: none;
  border-radius: 10px;
  padding: 6px 12px;
  font-size: 12px;
  font-weight: 500;
  min-width: 60px;
}

/* 快速操作 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4px 20px 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 700;
  color: #1a1a1a;
}

.section-more {
  font-size: 12px;
  color: #1a6b3c;
  cursor: pointer;
}

.quick-actions {
  display: flex;
  gap: 10px;
  padding: 0 16px 16px;
}

.quick-action {
  flex: 1;
  background: white;
  border-radius: 16px;
  padding: 14px 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  border: none;
}

.qa-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
}

.qa-icon.green {
  background: #e8f7ef;
  color: #1a6b3c;
}

.qa-icon.orange {
  background: #fff3e8;
  color: #e8621a;
}

.qa-icon.blue {
  background: #e8f0ff;
  color: #1a4eb8;
}

.qa-icon.purple {
  background: #f3e8ff;
  color: #6b1aa6;
}

.qa-label {
  font-size: 11px;
  color: #555;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
}

/* 活动列表 */
.activities-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 0 16px 80px;
}

.activities-scroll::-webkit-scrollbar {
  display: none;
}

.activity-card {
  background: white;
  border-radius: 18px;
  overflow: hidden;
  margin-bottom: 14px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  cursor: pointer;
}

.card-top {
  padding: 14px 16px;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.card-title {
  color: white;
  font-size: 16px;
  font-weight: 700;
  display: block;
}

.card-subtitle {
  color: rgba(255,255,255,0.75);
  font-size: 12px;
  margin-top: 3px;
  display: block;
}

.card-badge {
  background: rgba(255,255,255,0.2);
  color: white;
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 20px;
  font-weight: 500;
}

.card-body {
  padding: 14px 16px;
}

.card-info {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin-bottom: 12px;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: #666;
}

.info-item .icon {
  font-size: 13px;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.players-row {
  display: flex;
  align-items: center;
  gap: -4px;
}

.player-avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  margin-left: -6px;
  font-weight: 600;
  color: white;
}

.player-avatar:first-child {
  margin-left: 0;
}

.pa-gray {
  background: #999;
  font-size: 10px;
}

.join-btn {
  background: #1a6b3c;
  color: white;
  border: none;
  border-radius: 20px;
  padding: 7px 18px;
  font-size: 13px;
  font-weight: 600;
  min-width: 70px;
}

.join-btn:disabled {
  background: #ddd;
  color: #999;
  cursor: not-allowed;
}

/* 加载和空状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  color: #ccc;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 14px;
  color: #999;
}