/* detail.wxss */
.container {
  position: relative;
  min-height: 100vh;
  background: #f4f6f8;
}

/* 状态栏 */
.status-bar {
  height: 44px;
  background: transparent;
  color: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
}

.status-time {
  font-size: 15px;
  font-weight: 600;
  color: inherit;
}

.status-icons {
  display: flex;
  gap: 6px;
  align-items: center;
}

.status-icons span {
  font-size: 12px;
}

/* 头部英雄区 */
.detail-hero {
  background: linear-gradient(160deg, #1a6b3c, #2d9e5f);
  padding: 64px 20px 28px;
  position: relative;
  overflow: hidden;
}

.detail-hero::before {
  content: '🎾';
  position: absolute;
  right: -10px;
  bottom: -20px;
  font-size: 120px;
  opacity: 0.08;
}

.detail-back {
  position: absolute;
  top: 52px;
  left: 16px;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  color: white;
  font-size: 16px;
}

.detail-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(255,255,255,0.2);
  color: white;
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  margin-bottom: 10px;
}

.detail-title {
  font-size: 24px;
  font-weight: 800;
  color: white;
  margin-bottom: 6px;
  line-height: 1.2;
}

.detail-host {
  color: rgba(255,255,255,0.75);
  font-size: 13px;
}

/* 滚动内容区域 */
.detail-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 16px 16px 100px;
}

.detail-scroll::-webkit-scrollbar {
  display: none;
}

/* 详情卡片 */
.detail-card {
  background: white;
  border-radius: 18px;
  padding: 16px;
  margin-bottom: 14px;
}

.detail-card-title {
  font-size: 13px;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 6px;
}

/* 信息网格 */
.detail-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.detail-info-item {
  background: #f8f9fa;
  border-radius: 12px;
  padding: 12px;
}

.dii-label {
  font-size: 11px;
  color: #999;
  margin-bottom: 4px;
  display: block;
}

.dii-value {
  font-size: 14px;
  font-weight: 600;
  color: #1a1a1a;
}

/* 参与人员列表 */
.players-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.player-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px;
  border-radius: 12px;
  background: #f8f9fa;
}

.player-ava-lg {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
}

.player-info {
  flex: 1;
}

.player-name {
  font-size: 14px;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
}

.player-meta {
  font-size: 11px;
  color: #999;
  margin-top: 2px;
  display: block;
}

.player-level {
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 20px;
  font-weight: 500;
}

.level-adv {
  background: #fff3e8;
  color: #e8621a;
}

.level-mid {
  background: #e8f7ef;
  color: #1a6b3c;
}

.level-beg {
  background: #e8f0ff;
  color: #1a4eb8;
}

/* 空槽 */
.empty-slot {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px;
  border-radius: 12px;
  border: 2px dashed #e0e0e0;
}

.empty-ava {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: #f4f6f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: #ccc;
}

.empty-text {
  font-size: 13px;
  color: #bbb;
}

/* 地图占位符 */
.map-placeholder {
  background: linear-gradient(135deg, #e8f7ef, #d0edd9);
  border-radius: 14px;
  height: 120px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-bottom: 10px;
}

.map-placeholder .map-icon {
  font-size: 28px;
}

.map-placeholder .map-text {
  font-size: 13px;
  color: #1a6b3c;
  font-weight: 500;
}

.map-placeholder .map-sub {
  font-size: 11px;
  color: #66aa88;
}

/* 场地标签 */
.court-tag {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: #e8f7ef;
  color: #1a6b3c;
  font-size: 12px;
  padding: 5px 12px;
  border-radius: 20px;
  font-weight: 500;
}

/* 活动描述 */
.detail-description {
  font-size: 13px;
  color: #333;
  line-height: 1.5;
}

/* 活动规则 */
.detail-rules {
  font-size: 13px;
  color: #333;
  line-height: 1.5;
  white-space: pre-wrap;
}

/* 底部操作栏 */
.detail-action {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px 28px;
  background: white;
  border-top: 1px solid #f0f0f0;
  display: flex;
  gap: 10px;
  align-items: center;
}

.share-btn {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  background: #f4f6f8;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}

.join-main-btn {
  flex: 1;
  background: linear-gradient(135deg, #1a6b3c, #2d9e5f);
  color: white;
  border: none;
  border-radius: 14px;
  padding: 14px;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.join-main-btn:disabled {
  background: #ddd;
  color: #999;
}

/* 价格标签 */
.price-tag {
  font-size: 18px;
  font-weight: 800;
  color: #e8621a;
  margin-left: auto;
}

.price-per {
  font-size: 12px;
  color: #999;
  font-weight: 400;
}

/* 参与者头像颜色 */
.pa-green {
  background: #1a6b3c;
}

.pa-orange {
  background: #e8621a;
}

.pa-blue {
  background: #1a4eb8;
}

.pa-purple {
  background: #6b1a8b;
}

.pa-red {
  background: #c0392b;
}
